#!/usr/bin/env bash

set -euo pipefail

CLI_VERSION="${OQTOPUS_CLI_VERSION:-}"
CLI_REPO_OWNER="oqtopus-team"
CLI_REPO_NAME="oqtopus-cli"
TEMPLATE_BRANCH="main"

ENGINE_REPO="oqtopus-team/oqtopus-engine"
TRANQU_REPO="oqtopus-team/tranqu-server"
GATEWAY_REPO="oqtopus-team/device-gateway"

INSTALL_COMPONENTS=(engine tranqu gateway)
ENGINE_SERVICES=(core sse_engine mitigator estimator combiner)
ENGINE_UV_PROJECTS=(core combiner estimator mitigator)
SERVICES=(core sse_engine mitigator estimator combiner tranqu gateway)
START_ALL_ORDER=(gateway tranqu mitigator estimator combiner sse_engine core)
STOP_ALL_ORDER=(core sse_engine combiner estimator mitigator tranqu gateway)

CLOUD_LOCAL_CLOUD_REPO="oqtopus-team/oqtopus-cloud"
CLOUD_LOCAL_FRONTEND_REPO="oqtopus-team/oqtopus-frontend"
CLOUD_LOCAL_ADMIN_REPO="oqtopus-team/oqtopus-admin"
CLOUD_LOCAL_INSTALL_COMPONENTS=(cloud frontend admin)
CLOUD_LOCAL_SERVICES=(db worker user_signup admin provider user)
CLOUD_LOCAL_START_ORDER=(db worker user_signup admin provider user)
CLOUD_LOCAL_STOP_ORDER=(user provider admin user_signup worker db)

ENV_ROOT=""
INSTALL_ROOT=""
ENV_NAME=""
ACTIVE_SERVICE_LOCK=""

# -----------------------------------------------------------------------------
# Common output and command helpers
# -----------------------------------------------------------------------------

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'Warning: %s\n' "$*" >&2
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

need_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    die "'$1' is required but was not found on PATH."
  fi
}

# -----------------------------------------------------------------------------
# Help text
# -----------------------------------------------------------------------------

usage_top() {
  cat <<'EOF'
Usage:
  oqtopus <command> [args]

Commands:
  init         Create an OQTOPUS environment.
  backend      Manage local backend components and services.
  completion   Print shell completion scripts.
  version      Print the installed CLI version.
  help         Show help.

Run 'oqtopus <command> help' for command-specific help.
EOF
}

usage_init() {
  cat <<'EOF'
Usage:
  oqtopus init <env_name> --template backend
  oqtopus init <env_name> --template cloud-local

Creates a local OQTOPUS environment from the official template.
EOF
}

usage_backend() {
  cat <<'EOF'
Usage:
  oqtopus backend <command> [args]

Commands:
  install         Install backend component releases.
  build           Build backend runtime artifacts.
  versions        List available component versions.
  uninstall       Remove an installed release.
  update          Install the latest release of a component.
  start           Start a managed service.
  stop            Stop a managed service.
  restart         Restart a managed service.
  status          Show process status.
  device-status   Show or update gateway device status.
  info            Show backend environment information.
  help            Show help.
EOF
}

