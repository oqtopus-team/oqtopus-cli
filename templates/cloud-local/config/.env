ENV=local
DB_HOST=localhost
DB_NAME=main
DB_CONNECTOR=mysql+pymysql
ALLOW_ORIGINS=http://127.0.0.1:8000
ALLOW_CREDENTIALS=true
ALLOW_METHODS=*
ALLOW_HEADERS=*
LOG_LEVEL=DEBUG
USER_API_PORT=8080
PROVIDER_API_PORT=8888
ADMIN_API_PORT=8889
USER_SIGNUP_API_PORT=8890
STORAGE_DRIVER=local:minio
STORAGE_LOCAL_MINIO_BUCKET_NAME=oqtopus-oqtopus-dev
STORAGE_LOCAL_MINIO_USERNAME=minioadmin
STORAGE_LOCAL_MINIO_PASSWORD=minioadmin
STORAGE_LOCAL_MINIO_ENDPOINT_URL=http://localhost:9000
ALLOW_DELETION=true
EDITABLE_FIELDS=["name", "organization"]
VISIBLE_FIELDS=["id", "email", "name", "organization", "created_at"]
LOGIN_HISTORY_ENABLED=true
LOCAL_WORKER_SCHEDULING_RATE_S=60
